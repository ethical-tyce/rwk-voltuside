{
  "manifest_version": 3,
  "name": "Voltus IDE Bridge",
  "version": "1.3",
  "description": "Executes code from Voltus IDE into the active tab",
  "permissions": ["scripting", "activeTab", "tabs", "alarms"],
  "host_permissions": [
      "http://*/*",
      "https://*/*"
  ],
  
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  }
}